{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "matrix-web-part-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/matrixWebPart/MatrixWebPartWebPart.js",
          "manifest": "./src/webparts/matrixWebPart/MatrixWebPartWebPart.manifest.json"
        }
      ]
    },
    "card-web-part-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/cardWebPart/CardWebPartWebPart.js",
          "manifest": "./src/webparts/cardWebPart/CardWebPartWebPart.manifest.json"
        }
      ]
    },
    "md-card-web-part-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/mdCardWebPart/MdCardWebPartWebPart.js",
          "manifest": "./src/webparts/mdCardWebPart/MdCardWebPartWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "MatrixWebPartWebPartStrings": "lib/webparts/matrixWebPart/loc/{locale}.js",
    "CardWebPartWebPartStrings": "lib/webparts/cardWebPart/loc/{locale}.js",
    "MdCardWebPartWebPartStrings": "lib/webparts/mdCardWebPart/loc/{locale}.js"
  }
}
