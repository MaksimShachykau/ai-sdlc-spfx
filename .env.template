# SharePoint site hosting the AI-SDLC Role Matrix
# Full URL, no trailing slash
SP_SITE_URL=https://<tenant>.sharepoint.com/sites/<site-name>

# Server-relative path to the SitePages folder that contains the matrix hierarchy
# Pattern: /sites/<site-name>/SitePages/<matrix-folder-name>
SP_FOLDER_ROOT=/sites/<site-name>/SitePages/<matrix-folder-name>

# SPFx workbench URL opened by "gulp serve"
SP_WORKBENCH_URL=https://<tenant>.sharepoint.com/sites/<site-name>/_layouts/workbench.aspx
